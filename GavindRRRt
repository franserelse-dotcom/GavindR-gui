-- Tween + Seat teleport
local function teleportTweenAman(pos)
	if not hrp or not hrp.Parent then return end

	-- Buat seat sementara agar tidak jatuh
	local seat = Instance.new("Seat")
	seat.Size = Vector3.new(4, 1, 4)
	seat.Anchored = true
	seat.CanCollide = true
	seat.Name = "TweenSeat"
	seat.Position = pos + Vector3.new(0, -2.5, 0) -- dudukan sedikit di bawah
	seat.Parent = workspace

	-- Tween HRP ke posisi
	local tweenInfo = TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
	local tween = TweenService:Create(hrp, tweenInfo, {CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))})
	tween:Play()

	-- Setelah sampai, hapus seat setelah 1.5 detik
	task.delay(1e2, function()
		if seat and seat.Parent then
			seat:Destroy()
		end
	end)
end

