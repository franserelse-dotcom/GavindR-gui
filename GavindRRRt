	if x and y and z then
		local target = Vector3.new(tonumber(x), tonumber(y), tonumber(z))
		statusLabel.Text = "Teleporting..."
		teleportTweenAman(target)
		task.delay(1, function() statusLabel.Text = "✔️ Teleport Selesai!" end)
