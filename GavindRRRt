createButton("FORCEFIELD", UDim2.new(0, 1228, 0, 408), function()
	local function waitForCharacter()
		local char = player.Character
		while not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Humanoid") do
			char = player.Character or player.CharacterAdded:Wait()
			task.wait()
		end
		return char
	end

	local function createSafeZone27(character)
		local hrp = character:WaitForChild("HumanoidRootPart")

		local safeZone27 = Instance.new("Part")
		safeZone27.Name = 'SafeZone27'
		safeZone27.Anchored = true
		safeZone27.CanCollide = false
		safeZone27.Color = Color3.fromRGB(0,255,0)
		safeZone27.Size = _G.SafeZone27Size
		safeZone27.Material = Enum.Material.ForceField
		safeZone27.Transparency = 0.4
		safeZone27.Parent = workspace

		local selection = Instance.new("SelectionBox")
		selection.Adornee = safeZone27
		selection.Color3 = Color3.fromRGB(0, 170, 255)
		selection.LineThickness = 0.05
		selection.Parent = safeZone27

		local crySound = Instance.new("Sound")
		crySound.SoundId = "rbxassetid://5135809265"
		crySound.Volume = 2
		crySound.Looped = false
		crySound.Parent = safeZone27

		local function isPlayerModel(model)
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr.Character == model then return true end
			end
			return false
		end

		local function isAllowedModel(model)
			if isPlayerModel(model) then return true end
			if model:IsDescendantOf(workspace.CurrentCamera) then return true end
			return false
		end

		local function pushBack(model)
local hrp2 = model:FindFirstChild("HumanoidRootPart")  
			if not hrp2 then return end  
			local dir = (hrp2.Position - safeZone27.Position)  
			if dir.Magnitude == 0 then return end  
			hrp2.CFrame = CFrame.new(hrp2.Position + dir.Unit * math.random(3.1,6.1))  
			local s = crySound:Clone()  
			s.Parent = safeZone27  
			s:Play()  
			game.Debris:AddItem(s,5)  
		end

		-- dorong NPC yang nyentuh SafeZone
		safeZone27.Touched:Connect(function(hit)
			local model = hit.Parent
			if model and model:FindFirstChildOfClass("Humanoid") and not isAllowedModel(model) then
				pushBack(model)
			end
		end)

		-- cek terus NPC di sekitar SafeZone
		task.spawn(function()
			while safeZone27.Parent do
				local detected = {}
				for _, npcH in ipairs(workspace:GetDescendants()) do
					if npcH:IsA("Humanoid") and npcH.Parent and not isAllowedModel(npcH.Parent) then
						local npcHRP = npcH.Parent:FindFirstChild("HumanoidRootPart")
						if npcHRP then
							local diff = npcHRP.Position - hrp.Position
							if math.abs(diff.X) < _G.SafeZone27Size.X/2 and
							   math.abs(diff.Y) < _G.SafeZone27Size.Y/2 and
							   math.abs(diff.Z) < _G.SafeZone27Size.Z/2 then
								pushBack(npcH.Parent)
								table.insert(detected, npcH.Parent)
							end
						end
					end
				end
				updateList(detected)
				task.wait(0.05)
			end
		end)

		RunService.RenderStepped:Connect(function()
			if safeZone27 and safeZone27.Parent and hrp then
				safeZone27.CFrame = hrp.CFrame * CFrame.new(0, _G.SafeZone27Size.Y/2 - 5, 0)
				safeZone27.Size = _G.SafeZone27Size
			end
		end)

		character:WaitForChild("Humanoid").Died:Connect(function()
			if safeZone27 then safeZone27:Destroy() end
		end)
	end

	task.spawn(function()
		createSafeZone27(waitForCharacter())
	end)

	player.CharacterAdded:Connect(function(char)
		task.wait(1)
		createSafeZone27(char)
	end)
end)

