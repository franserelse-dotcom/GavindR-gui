local function buatBaris(nama, warna, posisiY, sumbu)
	local dist = 15 -- default jarak awal
	local container = Instance.new("Frame", frame)
	container.Size = UDim2.new(0, 350, 0, 40)
	container.Position = UDim2.new(0, 10, 0, posisiY)
	container.BackgroundTransparency = 1

	local label = Instance.new("TextLabel", container)
	label.Size = UDim2.new(0, 80, 0, 40)
	label.Text = nama .. ": " .. dist
	label.TextColor3 = Color3.fromRGB(255,255,255)
	label.BackgroundTransparency = 1
	label.Font = FONT
	label.TextSize = 16

	local btnMinus = Instance.new("TextButton", container)
	btnMinus.Size = UDim2.new(0, 25, 0, 25)
	btnMinus.Position = UDim2.new(0, 90, 0, 7)
	btnMinus.Text = "-"
	btnMinus.Font = FONT
	btnMinus.TextSize = 20
	btnMinus.BackgroundColor3 = Color3.fromRGB(255,100,100)
	btnMinus.TextColor3 = Color3.fromRGB(255,255,255)

	local btnPlus = Instance.new("TextButton", container)
	btnPlus.Size = UDim2.new(0, 25, 0, 25)
	btnPlus.Position = UDim2.new(0, 120, 0, 7)
	btnPlus.Text = "+"
	btnPlus.Font = FONT
	btnPlus.TextSize = 20
	btnPlus.BackgroundColor3 = Color3.fromRGB(100,255,100)
	btnPlus.TextColor3 = Color3.fromRGB(255,255,255)

	local btnGerak = Instance.new("TextButton", container)
	btnGerak.Size = UDim2.new(0, 100, 0, 40)
	btnGerak.Position = UDim2.new(0, 160, 0, 0)
	btnGerak.Text = "Gerak"
	btnGerak.Font = FONT
	btnGerak.TextSize = 18
	btnGerak.BackgroundColor3 = warna
	btnGerak.TextColor3 = Color3.fromRGB(255,255,255)

	-- Fungsi gerak arah tertentu
	local function gerak()
		local cf = hrp.CFrame
		if sumbu == "X+" then
			tweenMove(cf * CFrame.new(dist, 0, 0))
		elseif sumbu == "X-" then
			tweenMove(cf * CFrame.new(-dist, 0, 0))
		elseif sumbu == "Y+" then
			tweenMove(cf * CFrame.new(0, dist, 0))
		elseif sumbu == "Y-" then
			tweenMove(cf * CFrame.new(0, -dist, 0))
		elseif sumbu == "Z+" then
			tweenMove(cf * CFrame.new(0, 0, dist))
		elseif sumbu == "Z-" then
			tweenMove(cf * CFrame.new(0, 0, -dist))
		end
	end

	-- Tombol fungsi
	btnPlus.MouseButton1Click:Connect(function()
		dist += 1
		label.Text = nama .. ": " .. dist
	end)

	btnMinus.MouseButton1Click:Connect(function()
		if dist > 1 then
			dist -= 1
			label.Text = nama .. ": " .. dist
		end
	end)

	btnGerak.MouseButton1Click:Connect(gerak)
end

