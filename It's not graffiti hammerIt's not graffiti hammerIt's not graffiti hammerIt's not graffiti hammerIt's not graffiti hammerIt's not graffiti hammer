local function ConvertRemote(code)
	-- OnServerEvent → function
	code = code:gsub(
		"([%w_]+)%.OnServerEvent:Connect%(%s*function%((.-)%)",
		function(remoteName, args)
			return "function " .. remoteName .. "_OnServerEvent(" .. args .. ")"
		end
	)

	-- OnClientEvent → function
	code = code:gsub(
		"([%w_]+)%.OnClientEvent:Connect%(%s*function%((.-)%)",
		function(remoteName, args)
			return "function " .. remoteName .. "_OnClientEvent(" .. args .. ")"
		end
	)

	-- FireServer → panggil function
	code = code:gsub(
		"([%w_]+):FireServer%((.-)%)",
		function(remoteName, args)
			return remoteName .. "_OnServerEvent(game.Players.LocalPlayer, " .. args .. ")"
		end
	)

	-- FireClient / FireAllClients (optional hapus)
	code = code:gsub("[%w_]+:FireClient%b()", "")
	code = code:gsub("[%w_]+:FireAllClients%b()", "")

	return code
end
local function ConvertModuleAutoRun(code)
	-- hapus return module
	code = code:gsub("return%s+module", "")

	local calls = {}

	for funcName in code:gmatch("function%s+module%.([%w_]+)%s*%(") do
		table.insert(calls, "pcall(module." .. funcName .. ", plr)")
	end

	local autoCall = "\n\n-- AUTO RUN\n" .. table.concat(calls, "\n")

	return code .. autoCall
end
local function FixRequire(code)
	code = code:gsub(
		"require%((.-)%)",
		function(path)
			return "(function() local m="..path.."; if m and m.Source then return loadstring(m.Source)() end end)()"
		end
	)
	return code
end
