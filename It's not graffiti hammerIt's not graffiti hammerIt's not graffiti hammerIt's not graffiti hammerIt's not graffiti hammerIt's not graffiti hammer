local function getFullPath(inst, rootName)
	local path = rootName
	
	local stack = {}
	while inst and inst.Name ~= rootName do
		table.insert(stack,1,inst.Name)
		inst = inst.Parent
	end
	
	for _,name in ipairs(stack) do
		path ..= ":FindFirstChild(\""..name.."\")"
	end
	
	return path
end
