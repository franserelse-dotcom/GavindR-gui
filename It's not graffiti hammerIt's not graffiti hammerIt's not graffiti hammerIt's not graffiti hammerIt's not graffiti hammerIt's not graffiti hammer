local function SetupEditor(TextLOL, line, Scrol)
    local function UpdateLines()
        task.wait()

        local text = TextLOL.Text
        local _, lines = text:gsub("\n", "")
        lines += 1

        local nums = table.create(lines)
        for i = 1, lines do
            nums[i] = tostring(i)
        end

        line.Text = table.concat(nums, "\n")

        local height = lines * TextLOL.TextSize + 10
        TextLOL.Size = UDim2.new(1, -50, 0, height)
        line.Size = UDim2.new(0, 45, 0, height)

        Scrol.CanvasSize = UDim2.new(0, 0, 0, height)
    end

    Scrol:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
        local y = Scrol.CanvasPosition.Y
        TextLOL.Position = UDim2.new(0, 50, 0, -y)
        line.Position = UDim2.new(0, 0, 0, -y)
    end)

    TextLOL:GetPropertyChangedSignal("Text"):Connect(UpdateLines)
    TextLOL.Focused:Connect(UpdateLines)
    TextLOL.FocusLost:Connect(UpdateLines)

    UpdateLines()
end

