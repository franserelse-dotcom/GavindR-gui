local CHARACTER = getChar()
local HRP = CHARACTER:WaitForChild("HumanoidRootPart")
local ooopp = HRP.CFrame

-- Daftar nama giver (nama bisa ada di awalan / belakang)
local GIVER_NAMES = {
	"giver",
	"item",
	"itemstand",
	"box",
   "Claim",
   "Giver"
}

local function isGiverName(name)
	name = name:lower()
	for _, key in ipairs(GIVER_NAMES) do
		if string.find(name, key:lower()) then
			return true
		end
	end
	return false
end

local function getPart(obj)
	if obj:IsA("BasePart") then
		return obj
	end

	if obj:IsA("Model") then
		return obj:FindFirstChildWhichIsA("BasePart")
	end

	return nil
end

local function addSelectionBox(part)
	if not part then return end

	local sb = Instance.new("SelectionBox")
	sb.Adornee = part
	sb.LineThickness = 0.05
	sb.SurfaceColor3 = Color3.fromRGB(0,255,0)
	sb.Color3 = Color3.fromRGB(0,255,0)
	sb.Parent = part

	task.delay(1.5, function()
		if sb then sb:Destroy() end
	end)
end

local function teleportTo(target)
	if not HRP or not target then return end

	if typeof(target) == "CFrame" then
		HRP.CFrame = target
	elseif target:IsA("BasePart") then
		HRP.CFrame = target.CFrame + Vector3.new(0,3,0)
	end
end

