LogService.MessageOut:Connect(function(message, messageType)
	local color

	if message:find("TestService:") then
		color = Color3.fromRGB(120, 180, 255) -- biru TestService
	elseif messageType == Enum.MessageType.MessageOutput then
		color = Color3.fromRGB(255,255,255)
	elseif messageType == Enum.MessageType.MessageWarning then
		color = Color3.fromRGB(255,255,0)
	elseif messageType == Enum.MessageType.MessageError then
		color = Color3.fromRGB(255,60,60)
	end

	AddEntry(message, color)

	if messageType == Enum.MessageType.MessageError then
		local stack = debug.traceback()
		for _, l in ipairs(string.split(stack, "\n")) do
			if l:match("ServerScriptService") or l:match("LocalScript") or l:match("line") then
				AddEntry("  ↳ " .. l, Color3.fromRGB(200,120,120))
			end
		end
	end
