local BASE_CHAR_HEIGHT = 6
math.randomseed(os.clock())
local function scaleCharacterToPart(character, part)
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	local scaleFactor = part.Size.Y / BASE_CHAR_HEIGHT
	local desc = humanoid:GetAppliedDescription()
	desc.HeightScale = scaleFactor
	desc.WidthScale  = scaleFactor
	desc.DepthScale  = scaleFactor
	desc.HeadScale   = math.clamp(scaleFactor, 0.8, 3)
	humanoid:ApplyDescription(desc)
end
local function playRandomAnimation(humanoid)
	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end
	local anim = Instance.new("Animation")
	anim.AnimationId = ANIM_IDS[math.random(#ANIM_IDS)]
	local track = animator:LoadAnimation(anim)
	track.Looped = true
	track:Play()
	return track
end
