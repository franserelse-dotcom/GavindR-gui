        elseif text == "C" then
            current = ""
            firstNumber = nil
            operator = nil
            Display.Text = "0"
        elseif text == "=" then
            if firstNumber and operator and current ~= "" then
                local second = tonumber(current)
                local result = 0
                if operator == "+" then result = firstNumber + second end
                if operator == "-" then result = firstNumber - second end
                if operator == "×" then result = firstNumber * second end
                if operator == "÷" then
                    result = second ~= 0 and (firstNumber / second) or 0
                end
                Display.Text = firstNumber .. " " .. operator .. " " .. second .. " = " .. result
                current = tostring(result)
                firstNumber = nil
                operator = nil
            end
       else
         if current ~= "" then
             firstNumber = tonumber(current)
             operator = text
             Display.Text = current .. " " .. operator
             current = ""
          end
       end
    end)
end

