-- MULTI JUMP (SAFE)
local jumpConn
supSec:Toggle({
    Title = "🐰 Multi Jump",
    Callback = function(v)
        multiJumpEnabled = v

        if jumpConn then
            jumpConn:Disconnect()
            jumpConn = nil
        end

        if v then
            local jumps, max = 0, 30
            jumpConn = UIS.JumpRequest:Connect(function()
                local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                if hum and hum:GetState() == Enum.HumanoidStateType.Freefall and jumps < max then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    jumps += 1
                end
            end)

            LocalPlayer.CharacterAdded:Connect(function(c)
                c:WaitForChild("Humanoid").StateChanged:Connect(function(_, n)
                    if n == Enum.HumanoidStateType.Landed then
                        jumps = 0
                    end
                end)
            end)
        end
    end
})

