local function clearResults()
	for _,v in ipairs(list:GetChildren()) do
		if not v:IsA("UIListLayout") then
			v:Destroy()
		end
	end
end

local function getImage(v)
	if not v.image then
		return ""
	end

	local url

	if typeof(v.image) == "table" then
		url = v.image.url
	elseif typeof(v.image) == "string" then
		url = v.image
	end

	if not url or url == "" then
		return ""
	end

	if not string.find(url, "http") then
		url = "https://scriptblox.com" .. url
	end

	return url
end

local function searchScript(q)
	clearResults()

	local res = HttpService:RequestAsync({
		Url = "https://scriptblox.com/api/script/search?q="
			.. HttpService:UrlEncode(q) .. "&max=15",
		Method = "GET",
		Headers = {["User-Agent"] = "Roblox"}
	})

	local data = HttpService:JSONDecode(res.Body)
	if not data.result or not data.result.scripts then return end

	for _,v in ipairs(data.result.scripts) do
		local card = Instance.new("TextButton")
		card.Parent = list
		card.Size = UDim2.new(1,0,0,80)
		card.BackgroundColor3 = Color3.fromRGB(28,28,36)
		card.BorderSizePixel = 0
		card.Text = ""
		Instance.new("UICorner", card).CornerRadius = UDim.new(0,12)

		local ContentProvider = game:GetService("ContentProvider")

		local img = Instance.new("ImageLabel", card)
		img.Size = UDim2.fromOffset(60,60)
		img.Position = UDim2.fromOffset(10,10)
		img.BackgroundTransparency = 1
		img.ScaleType = Enum.ScaleType.Crop
		Instance.new("UICorner", img).CornerRadius = UDim.new(0,10)

		local imageUrl = getImage(v)
		if imageUrl ~= "" then
			img.Image = imageUrl
			task.spawn(function()
  			local success = pcall(function()
	  		ContentProvider:PreloadAsync({img})
	   	end)
				if not success then
					img.Image = "rbxassetid://7866373963" -- fallback icon
				end
			end)
		else
			img.Image = "rbxassetid://95330729950928" -- fallback kalau kosong
		end
      

		-- TITLE
		local title = Instance.new("TextLabel", card)
		title.Position = UDim2.fromOffset(80,10)
		title.Size = UDim2.new(1,-90,0,22)
		title.TextXAlignment = Enum.TextXAlignment.Left
		title.TextWrapped = true
		title.Text = v.title or "No Title"
		title.Font = Enum.Font.GothamBold
		title.TextSize = 14
		title.TextColor3 = Color3.new(1,1,1)
		title.BackgroundTransparency = 1

