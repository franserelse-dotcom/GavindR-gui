		local gameName = Instance.new("TextLabel", card)
		gameName.Position = UDim2.fromOffset(80,34)
		gameName.Size = UDim2.new(1,-90,0,18)
		gameName.TextXAlignment = Enum.TextXAlignment.Left
		gameName.Text = (v.game and v.game.name) or "Universal Script"
		gameName.Font = Enum.Font.Gotham
		gameName.TextSize = 12
		gameName.TextColor3 = Color3.fromRGB(180,180,180)
		gameName.BackgroundTransparency = 1

		-- VERIFIED
		if v.verified then
			local ver = Instance.new("TextLabel", card)
			ver.Text = "✔ VERIFIED"
			ver.Size = UDim2.fromOffset(80,18)
			ver.Position = UDim2.fromOffset(80,56)
			ver.TextSize = 11
			ver.TextColor3 = Color3.fromRGB(0,200,255)
