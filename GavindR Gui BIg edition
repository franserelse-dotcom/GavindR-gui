-- CONFIG
local activeNotifs = {}
local notifCount = {}
local notifCooldown = {}

local MAX_NOTIFS = 5
local COOLDOWN = 0.4
local NOTIF_HEIGHT = 55
local BASE_Y = -20

-- FUNCTION
function ShowNotification(text, duration)
	duration = duration or 2

	-- cooldown anti spam
	local now = tick()
	if notifCooldown[text] and now - notifCooldown[text] < COOLDOWN then
		return
	end
	notifCooldown[text] = now

	-- merge notif sama
	notifCount[text] = (notifCount[text] or 0) + 1
	local displayText = text
	if notifCount[text] > 1 then
		displayText = text .. " (x" .. notifCount[text] .. ")"
	end

	-- max notif
	if #activeNotifs >= MAX_NOTIFS then
		local old = table.remove(activeNotifs, 1)
		if old then old:Destroy() end
	end

	-- label
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 300, 0, 45)
	label.Position = UDim2.new(0.5, -150, 1, 60)
	label.AnchorPoint = Vector2.new(0, 1)
	label.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.BorderSizePixel = 0
	label.BackgroundTransparency = 0.15
	label.Text = displayText
	label.Parent = gui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent = label

	table.insert(activeNotifs, label)

	-- posisi
	for i, notif in ipairs(activeNotifs) do
		TweenService:Create(
			notif,
			TweenInfo.new(0.25),
			{Position = UDim2.new(0.5, -150, 1, BASE_Y - ((i - 1) * NOTIF_HEIGHT))}
		):Play()
	end

	-- keluar
	task.delay(duration, function()
		TweenService:Create(
			label,
			TweenInfo.new(0.25),
			{
				Position = UDim2.new(0.5, -150, 1, 60),
				TextTransparency = 1,
				BackgroundTransparency = 1
			}
		):Play()
		task.wait(0.3)

		for i, v in ipairs(activeNotifs) do
			if v == label then
				table.remove(activeNotifs, i)
				break
			end
		end

		label:Destroy()

		-- rapihin ulang
		for i, notif in ipairs(activeNotifs) do
			TweenService:Create(
				notif,
				TweenInfo.new(0.2),
				{Position = UDim2.new(0.5, -150, 1, BASE_Y - ((i - 1) * NOTIF_HEIGHT))}
			):Play()
		end
	end)
end

