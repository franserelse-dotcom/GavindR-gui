local function convertModel(model)

	id = 0
	map = {}
	scriptBuffer = ""

	local instanceCode = ""
	local scriptCode = ""

	local code = "local model = Instance.new('Model')\n"
	code ..= "model.Name = '"..model.Name.."'\n"
	code ..= "model.Parent = workspace\n\n"

	for _,v in ipairs(model:GetChildren()) do
		code ..= convertObj(v,"model")
	end

	instanceCode = code
	scriptCode = scriptBuffer

	return instanceCode, scriptCode
end
