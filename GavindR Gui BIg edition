-- helper: find building ancestor that contains a Keys folder
local function findBuildingWithKeys(doorPart)
	local node = doorPart.Parent
	while node and node ~= workspace do
		if node:FindFirstChild("Keys") then
			return node -- this is the building/folder that contains Keys
		end
		node = node.Parent
	end
	return nil
end

-- helper: extract tokens from door name (remove "door" prefix or split by non-alnum)
local function extractTokens(doorName)
	local s = doorName:lower()
	-- remove leading "door" if present
	s = s:gsub("^door[_%s%-]*", "")
	-- split by non-alphanumeric
	local tokens = {}
	for token in s:gmatch("[%w]+") do
		table.insert(tokens, token)
	end
	return tokens
end

-- helper: find best key name for a doorPart
local function findKeyForDoor(doorPart)
	local building = findBuildingWithKeys(doorPart)
	if not building then return nil end
	local keysFolder = building:FindFirstChild("Keys")
	if not keysFolder then return nil end

	-- collect key names in lowercase
	local keyObjs = keysFolder:GetChildren()
	local names = {}
	for _,k in ipairs(keyObjs) do
		names[#names+1] = {obj = k, name = tostring(k.Name), lname = tostring(k.Name):lower()}
	end

	-- if no keys, nil
	if #names == 0 then return nil end

	-- try to match tokens from door
	local tokens = extractTokens(doorPart.Name)
	-- try exact token containment first (longest token first)
	table.sort(tokens, function(a,b) return #a > #b end)
	for _,tok in ipairs(tokens) do
		for _,entry in ipairs(names) do
			if entry.lname:find(tok, 1, true) then
				return entry.obj.Name
			end
		end
	end

	-- fallback: try matching any word from door name against key names
	local doorWords = {}
	for w in doorPart.Name:lower():gmatch("[%w]+") do table.insert(doorWords, w) end
	for _, w in ipairs(doorWords) do
		for _,entry in ipairs(names) do
			if entry.lname:find(w, 1, true) then
				return entry.obj.Name
			end
		end
	end

	-- final fallback: if there's exactly one key in folder, return it
	if #names == 1 then
		return names[1].obj.Name
	end

	-- nothing found
	return nil
end

