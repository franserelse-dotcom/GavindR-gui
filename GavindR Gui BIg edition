local function enableDevil(tool)
	local handle = tool:FindFirstChild("Handle")
	if not handle or handle:FindFirstChild("DevilActive") then return end

	local sizeVal = Instance.new("Vector3Value")
	sizeVal.Name = "OriginalSize"
	sizeVal.Value = handle.Size
	sizeVal.Parent = handle

	local transVal = Instance.new("NumberValue")
	transVal.Name = "OriginalTransparency"
	transVal.Value = handle.Transparency
	transVal.Parent = handle

	local mark = Instance.new("BoolValue")
	mark.Name = "DevilActive"
	mark.Parent = handle

	local visual = handle:Clone()
	visual.Name = "DevilVisual"
	visual.Transparency = 0
	visual.Color = SETTINGS.DevilColor
	visual.CanCollide = false
	visual.Massless = true
	visual:ClearAllChildren()
	visual.Parent = tool

	local weld = Instance.new("WeldConstraint")
	weld.Part0 = handle
	weld.Part1 = visual
	weld.Parent = visual

	local fire = Instance.new("Fire")
	fire.Color = SETTINGS.AuraColor
	fire.SecondaryColor = Color3.new(0,0,0)
	fire.Heat = 25
	fire.Size = 18
	fire.Parent = visual

	handle.Size = SETTINGS.HitboxSize
	handle.Transparency = SETTINGS.ShowHitbox and 0.7 or 1
	handle.CanCollide = false

	local mesh = handle:FindFirstChildOfClass("SpecialMesh")
	if mesh then
		mesh.Scale = Vector3.new(0,0,0)
	end
end

local function disableDevil(tool)
	local handle = tool:FindFirstChild("Handle")
	if not handle then return end

	if handle:FindFirstChild("DevilActive") then
		local sizeVal = handle:FindFirstChild("OriginalSize")
		local transVal = handle:FindFirstChild("OriginalTransparency")

		if sizeVal then handle.Size = sizeVal.Value end
		if transVal then handle.Transparency = transVal.Value end

		handle.CanCollide = true

		local mesh = handle:FindFirstChildOfClass("SpecialMesh")
		if mesh then
			mesh.Scale = Vector3.new(1,1,1)
		end

		local visual = tool:FindFirstChild("DevilVisual")
		if visual then visual:Destroy() end

		handle.DevilActive:Destroy()
		if sizeVal then sizeVal:Destroy() end
		if transVal then transVal:Destroy() end
	end
end

