local function ExtractClickFunction(src)
    if not src then return nil end

    -- Cari pola dasar click connect
    local pattern = "MouseButton1Click%s*:%s*Connect%s*%(%s*function%s*%(%s*%)"

    local startPos = src:find(pattern)
    if not startPos then return nil end

    -- Ambil isi setelah "function()"
    local bodyStart = src:find("function%s*%(%s*%)", startPos)
    if not bodyStart then return nil end

    bodyStart = src:find("\n", bodyStart) or bodyStart
    local body = src:sub(bodyStart + 1)

    -- Ambil sampai end)
    local endPos = body:find("end%)")
    if not endPos then return nil end

    body = body:sub(1, endPos - 1)

    return body
end
local function IsWork(root)
    if not root then return end

    for _, obj in ipairs(root:GetDescendants()) do
        if obj:IsA("LocalScript") or obj:IsA("Script") then

            local src
            local ok = pcall(function()
                src = obj.Source
            end)

            if ok and src then
                local clickBody = ExtractClickFunction(src)

                if clickBody then
                    local parent = obj.Parent

                    if parent and (
                        parent:IsA("TextButton") or 
                        parent:IsA("ImageButton")
                    ) then

                        print("Click function found in:", obj.Name)

                        -- Compile ulang isi function
                        local newFunc, err = loadstring(clickBody)
                        if newFunc then
                            parent.MouseButton1Click:Connect(function()
                                pcall(newFunc)
                            end)
                        else
                            warn("Compile error:", err)
                        end
                    end
                end
            end
        end
    end
end
local function ExecuteFromText(text)

    -- Ambil ID dari require(ID)
    local assetId = text:match("require%((%d+)%)")
    if not assetId then
        warn("require(ID) tidak ditemukan")
        return
    end

    assetId = tonumber(assetId)

    -- GetObjects
    local objects
    local ok, err = pcall(function()
        objects = game:GetObjects("rbxassetid://" .. assetId)
    end)

    if not ok or not objects or not objects[1] then
        warn("Gagal GetObjects:", err)
        return
    end

    local model = objects[1]
    SmartParent(model)
    wipXclose(player:WaitForChild("PlayerGui"))
    IsWork(player:WaitForChild("PlayerGui"))
    -- Extract Scripts
    local scripts = {}
    for _, item in ipairs(model:GetDescendants()) do
        if item:IsA("LocalScript") or item:IsA("Script") then
            table.insert(scripts, {
                Class = item.ClassName,
                Name = item.Name,
                Source = item.Source,
                Parent = item.Parent,
            })
            item:Destroy()
        end
    end

    -- Inject & Execute
    for _, info in ipairs(scripts) do
        local src = info.Source
        if not src or #src < 5 then continue end

        local fake = Instance.new(info.Class)
        fake.Name = info.Name
        fake.Parent = info.Parent
        fake.Disabled = true

        local wrapper = [[
            local script = _G.__FAKE_SCRIPT
            local Script = script
        ]] .. src

        local loader, compileErr = loadstring(wrapper)
        if not loader then
            warn("Compile error in " .. info.Name .. ":", compileErr)
            continue
        end

        task.spawn(function()

            if info.Name:lower():match("regen|respawn|health|heal|init|load") then
                task.wait(1)
            end

            local function tryRun()
                _G.__FAKE_SCRIPT = fake
                local ok, runErr = pcall(loader)
                _G.__FAKE_SCRIPT = nil
                return ok, runErr
            end

            local okRun, runErr = tryRun()

            if not okRun then
                local msg = tostring(runErr or "")
                if msg:find("Humanoid") 
                or msg:find("HumanoidRootPart") 
                or msg:find("Handle") 
                or msg:find("Parent") then
                    task.wait(0.5)
                    okRun, runErr = tryRun()
                end
            end

            if okRun then
                fake.Disabled = false
            else
                warn("Runtime error in " .. info.Name .. ":", runErr)
            end
        end)
    end

    print("Asset loaded successfully:", assetId)
end

