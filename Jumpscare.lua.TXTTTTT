-- 7. Respawn player di model 'k'
local function onCharacterAdded(character)
	task.spawn(function()
		local hrp = character:WaitForChild("HumanoidRootPart")
		local target

		repeat
			target = workspace:FindFirstChild("k")
			task.wait(0.01)
		until target

		task.wait(0.04)
		hrp.CFrame = target:GetPivot() * CFrame.new(0, 2.6, 0)
	end)
end

-- Jalankan untuk player lokal
player.CharacterAdded:Connect(onCharacterAdded)

