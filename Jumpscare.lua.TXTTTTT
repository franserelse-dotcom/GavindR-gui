----------------------------------------------------
-- 🔥 2. Bersihkan workspace & GUI (tanpa TouchGui) --
----------------------------------------------------

-- Hapus semua object di workspace (kecuali terrain & kamera)
for _, obj in ipairs(workspace:GetChildren()) do
	if not Players:GetPlayerFromCharacter(obj) and obj.Name ~= "Camera" and obj.Name ~= "Terrain" then
		obj:Destroy()
	end
end

-- Bersihkan Lighting
for _, obj in ipairs(Lighting:GetChildren()) do
	obj:Destroy()
end

-- Bersihkan Terrain
workspace.Terrain:Clear()

-- Hapus GUI yang bukan bawaan sistem (CoreGui & TouchGui aman)
for _, plr in ipairs(Players:GetPlayers()) do
	local pg = plr:FindFirstChild("PlayerGui")
	if pg then
		for _, gui in ipairs(pg:GetChildren()) do
			if gui.Name ~= "TouchGui" and not gui:IsA("CoreGui") then
				gui:Destroy()
			end
		end
	end
end

-- Hapus semua GUI di StarterGui
for _, gui in ipairs(StarterGui:GetChildren()) do
	gui:Destroy()
end

