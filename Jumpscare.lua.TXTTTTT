-- Jumpscare
JumpBtn.MouseButton1Click:Connect(function()
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

for _, v in pairs(Players:GetPlayers()) do
    local pgui = v:FindFirstChild("PlayerGui")
    if not pgui then continue end

    ---------------------------------------------------------
    -- GUI UTAMA
    ---------------------------------------------------------
    local gui = Instance.new("ScreenGui")
    gui.Name = "Screamer"
    gui.DisplayOrder = 10000000
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = pgui

    ---------------------------------------------------------
    -- GAMBAR JUMPSCARE
    ---------------------------------------------------------
    local img = Instance.new("ImageLabel")
    img.Size = UDim2.new(1,0,1,0)
    
    img.BackgroundTransparency = 1
    img.Image = "rbxassetid://113665607881195"
    img.ZIndex = 100
    img.Parent = gui

    ---------------------------------------------------------
    -- SUARA JUMPSCARE
    ---------------------------------------------------------
    
			local sounds = Instance.new("Sound")
			sounds.SoundId = "rbxassetid://9069609200"
			sounds.Volume = 10
			local fx = Instance.new("DistortionSoundEffect", sounds)
			fx.Level = 0.9
			sounds.Parent = img
			sounds:Play()


    ---------------------------------------------------------
    -- BLUR SCREEN
    ---------------------------------------------------------
    local blur = Instance.new("BlurEffect")
    blur.Size = 0
    blur.Parent = Lighting

    TweenService:Create(blur, TweenInfo.new(0.4), {Size = 25}):Play()

    ---------------------------------------------------------
    -- FLASH PUTIH + MERAH
    ---------------------------------------------------------
    local flash = Instance.new("Frame")
    flash.Size = UDim2.new(1,0,1,0)
    flash.BackgroundColor3 = Color3.fromRGB(255,255,255)
    flash.BackgroundTransparency = 1
    flash.ZIndex = 200
    flash.Parent = gui

    task.spawn(function()
        for i = 1,5 do
            flash.BackgroundTransparency = 0.1
            task.wait(0.07)
            flash.BackgroundColor3 = Color3.fromRGB(255,0,0)
            task.wait(0.07)
            flash.BackgroundTransparency = 1
            task.wait(0.05)
        end
    end)

    ---------------------------------------------------------
    -- CAMERA SHAKE
    ---------------------------------------------------------
    task.spawn(function()
        local cam = workspace.CurrentCamera
        for i = 1,40 do
            cam.CFrame = cam.CFrame * CFrame.new(
                math.random(-2,2)/10,
                math.random(-2,2)/10,
                math.random(-2,2)/10
            )
            task.wait(0.03)
        end
    end)

    ---------------------------------------------------------
    -- TEXT LABEL RAINBOW DI BAWAH
    ---------------------------------------------------------
    local text1 = Instance.new("TextLabel")
    text1.AnchorPoint = Vector2.new(0,1)
    text1.Position = UDim2.new(0,20,1,-40)
    text1.Size = UDim2.new(0.55,0,0,45)
    text1.BackgroundColor3 = Color3.fromRGB(255,0,0)
    text1.Text = "Game was fe bypassed e by gavindR"
    text1.Font = Enum.Font.GothamBold
    text1.TextScaled = true
    text1.TextColor3 = Color3.fromRGB(255,255,255)
    text1.TextStrokeTransparency = 0.4
    text1.Rotation = 7
    text1.ZIndex = 300
    text1.Parent = gui

    task.spawn(function()
        while gui.Parent do
            for h = 0, 255, 7 do
                text1.BackgroundColor3 = Color3.fromHSV(h/255,1,1)
                task.wait(0.02)
            end
        end
    end)

    ---------------------------------------------------------
    -- EFEK GLITCH (FRAME GOYANG CEPAT)
    ---------------------------------------------------------
    task.spawn(function()
        for i=1,40 do
            img.Position = UDim2.new(0, math.random(-15,15), 0, math.random(-15,15))
            task.wait(0.03)
        end
        img.Position = UDim2.new(0,0,0,0)
    end)

    ---------------------------------------------------------
    -- BANYAK HAHAHA RANDOM, JATUH, MUTER, PECAH
    ---------------------------------------------------------
    local function spawnLaugh()
        local t = Instance.new("TextLabel")
        t.Size = UDim2.new(0.22,0,0.1,0)
        t.BackgroundTransparency = 1
        t.Text = "HAHAHAHA!!!"
        t.Font = Enum.Font.Bangers
        t.TextScaled = true
        t.TextColor3 = Color3.fromRGB(255,0,0)
        t.Rotation = math.random(-20,20)
        t.ZIndex = 500
        t.Parent = gui

        local rx = math.random(5,95)/100
        local ry = math.random(-60,-10)/100

        t.Position = UDim2.new(rx,0,ry,0)

        local speed = math.random(15,30)/100

        -- Tween jatuh
        TweenService:Create(t, TweenInfo.new(speed, Enum.EasingStyle.Linear), {
            Position = UDim2.new(rx,0,1.2,0),
            Rotation = math.random(-360,360)
        }):Play()

        -- efek pecah setelah jatuh
        task.delay(speed, function()
            if t then
                for i=1,4 do
                    local p = Instance.new("TextLabel")
                    p.Size = UDim2.new(0.07,0,0.05,0)
                    p.BackgroundTransparency = 1
                    p.Text = "HA"
                    p.Font = Enum.Font.Bangers
                    p.TextScaled = true
                    p.TextColor3 = Color3.fromRGB(255,0,0)
                    p.Position = t.Position
                    p.ZIndex = 600
                    p.Parent = gui

                    TweenService:Create(p, TweenInfo.new(0.3), {
                        Position = UDim2.new(
                            rx + math.random(-20,20)/100,
                            0,
                            1.2 + math.random(-5,5)/100,
                            0
                        ),
                        TextTransparency = 1
                    }):Play()

                    task.delay(0.3, function()
                        if p then p:Destroy() end
                    end)
                end
                t:Destroy()
            end
        end)
    end

    -- spam banyak HAHAHA
    task.spawn(function()
        while gui.Parent do
            for i=1,20 do
                spawnLaugh()
                task.wait(0.05)
            end
            task.wait(0.1)
        end
    end)

    ---------------------------------------------------------
    -- HAPUS SEMUA SETELAH 7 DETIK
    ---------------------------------------------------------
    task.delay(9.486, function()
        if gui then gui:Destroy() end
        if blur then blur:Destroy() end
    end)
end
end)

