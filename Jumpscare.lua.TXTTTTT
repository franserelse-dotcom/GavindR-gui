--// SERVICES
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

--// GUI
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 420, 0, 260)
Frame.Position = UDim2.new(0.5, -210, 0.5, -130)
Frame.BackgroundColor3 = Color3.fromRGB(47,199,205)
Frame.Active = true
Frame.Draggable = true

local Title = Instance.new("TextLabel", Frame)
Title.Size = UDim2.new(1,0,0,30)
Title.BackgroundColor3 = Color3.fromRGB(70,70,70)
Title.Text = "GavindR GUI"
Title.TextScaled = true
Title.TextColor3 = Color3.fromRGB(170,60,255)

--// BUTTON MAKER
local function makeButton(text, x, y, w)
	local b = Instance.new("TextButton", Frame)
	b.Size = UDim2.new(0, w or 120, 0, 35)
	b.Position = UDim2.new(0,x,0,y)
	b.Text = text
	b.BackgroundColor3 = Color3.fromRGB(145,255,102)
	b.BorderSizePixel = 2
	return b
end

--// BUTTONS
local DecalBtn    = makeButton("Decal Spam", 10, 40)
local ParticleBtn = makeButton("Particle Spam", 10, 80)

local Sky1Btn     = makeButton("Skybox", 10, 120)
local Sky2Btn     = makeButton("Skybox2", 10, 160)

local Sound1Btn   = makeButton("Sound", 150, 40)
local Sound2Btn   = makeButton("Sound2", 150, 80)

local MsgBtn      = makeButton("Message", 150, 120)
local HintBtn     = makeButton("Hint", 150, 160)

local R6Btn       = makeButton("Realm", 300, 40)
local JumpBtn     = makeButton("Jumpscare All", 110, 205, 200)

--// FUNCTIONS

-- Decal Spam
DecalBtn.MouseButton1Click:Connect(function()
local de= [[
rbxassetid://77005694743685
]]
function exPro(root)
			for _, v in pairs(root:GetChildren()) do
				if v:IsA("Decal") and v.Texture ~= de then
					v.Parent = nil
				elseif v:IsA("BasePart") then
					v.Material = "Plastic"
					v.Transparency = 0
					local One = Instance.new("Decal", v)
					local Two = Instance.new("Decal", v)
					local Three = Instance.new("Decal", v)
					local Four = Instance.new("Decal", v)
					local Five = Instance.new("Decal", v)
					local Six = Instance.new("Decal", v)
					One.Texture = de
					Two.Texture = de
					Three.Texture = de
					Four.Texture = de
					Five.Texture = de
					Six.Texture = de
					One.Face = "Front"
					Two.Face = "Back"
					Three.Face = "Right"
					Four.Face = "Left"
					Five.Face = "Top"
					Six.Face = "Bottom"
				end
				exPro(v)
			end
		end
		function asdf(root)
			for _, v in pairs(root:GetChildren()) do
				asdf(v)
			end
		end
		exPro(game.Workspace)
		asdf(game.Workspace)
end)

-- Particle Spam
ParticleBtn.MouseButton1Click:Connect(function()
local ID = "rbxassetid://77005694743685"
		local t1 = "rbxassetid://77005694743685"
		local t2 = "rbxassetid://77005694743685"
		local t3 = "rbxassetid://77005694743685"
	
		local Skybox = false
		local particle = true
	
		if Skybox == true then
			local sky = Instance.new("Sky")
			sky.Parent = game.Lighting
			sky.SkyboxBk = ID
			sky.SkyboxDn = ID
			sky.SkyboxFt = ID
			sky.SkyboxLf = ID
			sky.SkyboxRt = ID
			sky.SkyboxUp = ID
		end
	
		if particle == true then
			-- Función para crear un ParticleEmitter con una textura específica
			local function createParticleEmitter(parent, texture)
				local pe = Instance.new("ParticleEmitter", parent)
				pe.Texture = texture
				pe.VelocitySpread = 15
				pe.Rate = 6 -- Ajusta la tasa de emisión (partículas por segundo)
				pe.Lifetime = NumberRange.new(1000, 1000) -- Ajusta el tiempo de vida de las partículas
				pe.Size = NumberSequence.new(1) -- Ajusta el tamaño de las partículas
			end
	
			-- Aplicar los ParticleEmitters a todas las Partes en el Workspace
			for _, v in pairs(game.Workspace:GetChildren()) do
				if v:IsA("Part") then
					createParticleEmitter(v, t1)
					createParticleEmitter(v, t2)
					createParticleEmitter(v, t3)
				end
			end
	
			-- Aplicar los ParticleEmitters a todas las Partes dentro de los Modelos en el Workspace
			for _, model in pairs(game.Workspace:GetChildren()) do
				if model:IsA("Model") then
					for _, part in pairs(model:GetChildren()) do
						if part:IsA("Part") then
							createParticleEmitter(part, t1)
							createParticleEmitter(part, t2)
							createParticleEmitter(part, t3)
						end
					end
				end
			end
		end
end)

-- Clear Sky
local function clearSky()
	for _,v in ipairs(Lighting:GetChildren()) do
		if v:IsA("Sky") then
			v:Destroy()
		end
	end
end

